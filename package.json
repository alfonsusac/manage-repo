{
  "name": "manage-repo",
  "description": "A tool to manage your repositories",
  "version": "0.0.20",
  "module": "index.ts",
  "type": "module",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "prepublishOnly": "bun scripts/prepublish.ts",
    "postpublish": "bun scripts/postpublish.ts",
    "dev": "bun --watch src/cmd.ts",
    "version": "bun scripts/version.ts",
    "build": "bun scripts/build.ts",
    "start": "bun run build && bun dist/cmd.js",
    "postinstall": "bun -e \" \" || echo Bun required! Please install bun via `npm i -g bun` or `pnpm i -g bun`"
  },
  "dependencies": {},
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react-dom": "^19.2.3",
    "bun": "^1.3.11",
    "bun-plugin-tailwind": "^0.1.2",
    "commander": "^14.0.3",
    "lazy-cn": "^1.0.0",
    "nanoid": "^5.1.7",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1",
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "bin": {
    "manage-repo": "./dist/cmd.js"
  },
  "files": [
    "dist"
  ]
}