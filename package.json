{
  "name": "manage-repo",
  "description": "A tool to manage your repositories",
  "version": "0.0.9",
  "module": "index.ts",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "prepublishOnly": "bun scripts/publish.ts",
    "dev": "bun --watch src/cmd.ts",
    "version": "bun scripts/version.ts",
    "start": "bun run build && dist/manage_repo"
  },
  "dependencies": {
    "@types/node": "^25.5.0",
    "@types/react-dom": "^19.2.3",
    "bun-plugin-tailwind": "^0.1.2",
    "commander": "^14.0.3",
    "lazy-cn": "^1.0.0",
    "nanoid": "^5.1.7",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.1"
  },
  "bin": {
    "manage-repo": "./dist/manage_repo"
  },
  "files": [
    "dist"
  ]
}