{
  "name": "manage-repo",
  "description": "A tool to manage your repositories",
  "version": "0.0.7",
  "module": "index.ts",
  "type": "module",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "build": "bun build src/cmd.ts --outdir=dist --minify ",
    "prepublishOnly": "bun scripts/publish.ts",
    "dev": "bun --watch src/cmd.ts",
    "version": "bun scripts/version.ts"
  },
  "dependencies": {
    "@types/node": "^25.5.0",
    "@types/react-dom": "^19.2.3",
    "commander": "^14.0.3",
    "lazy-cn": "^1.0.0",
    "nanoid": "^5.1.7",
    "react-dom": "^19.2.4"
  },
  "bin": {
    "manage-repo": "./dist/cmd.js"
  },
  "files": [
    "dist"
  ]
}